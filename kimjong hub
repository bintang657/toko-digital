local _flyBody = nil
local _flyGyro = nil

_Features.flyHack = function(enabled)
    _States.fly_hack = enabled

    if enabled then
        _Util.notify("Fly", "Fly ENABLED (Press E to go up, Q to go down)", 3)

        task.spawn(function()
            local _hrp = _Util.getHRP()
            if not _hrp then return end

            -- Create flight mechanics
            _flyBody = Instance.new("BodyVelocity")
            _flyBody.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            _flyBody.Velocity = Vector3.new(0, 0, 0)
            _flyBody.Parent = _hrp

            _flyGyro = Instance.new("BodyGyro")
            _flyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            _flyGyro.P = 9e4
            _flyGyro.Parent = _hrp

            local _fly_speed = _States.speed_value or 50
            local _camera = _WS.CurrentCamera

            local _conn
            _conn = _RunS.RenderStepped:Connect(function()
                if not _States.fly_hack then
                    pcall(function()
                        if _flyBody then _flyBody:Destroy(); _flyBody = nil end
                        if _flyGyro then _flyGyro:Destroy(); _flyGyro = nil end
                    end)
                    _conn:Disconnect()
                    return
                end

                pcall(function()
                    if _flyBody and _flyGyro and _hrp then
                        _flyGyro.CFrame = _camera.CFrame

                        local _vel = Vector3.new(0, 0, 0)
                        local _cf = _camera.CFrame

                        if _UIS:IsKeyDown(Enum.KeyCode.W) then
                            _vel = _vel + _cf.LookVector * _fly_speed
                        end
                        if _UIS:IsKeyDown(Enum.KeyCode.S) then
                            _vel = _vel - _cf.LookVector * _fly_speed
                        end
                        if _UIS:IsKeyDown(Enum.KeyCode.A) then
                            _vel = _vel - _cf.RightVector * _fly_speed
                        end
                        if _UIS:IsKeyDown(Enum.KeyCode.D) then
                            _vel = _vel + _cf.RightVector * _fly_speed
                        end
                        if _UIS:IsKeyDown(Enum.KeyCode.E) then
                            _vel = _vel + Vector3.new(0, _fly_speed, 0)
                        end
                        if _UIS:IsKeyDown(Enum.KeyCode.Q) then
                            _vel = _vel - Vector3.new(0, _fly_speed, 0)
                        end

                        _flyBody.Velocity = _vel
                    end
                end)
            end)

            _addConnection("fly", _conn)
        end)
    else
        pcall(function()
            if _flyBody then _flyBody:Destroy(); _flyBody = nil end
            if _flyGyro then _flyGyro:Destroy(); _flyGyro = nil end
        end)
        _removeConnection("fly")
        _Util.notify("Fly", "Fly DISABLED", 2)
    end
end

