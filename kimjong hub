        pcall(function()
            -- Update fitur yang perlu continuous loop
            if Features.SpeedHack then
                applySpeed()
            end
            if Features.FlyHack then
                fly()
            end
            if Features.Noclip then
                noclip()
            end
            if Features.InfiniteStamina then
                infiniteStamina()
            end
            if Features.GodMode then
                godMode()
            end
            if Features.InfiniteBait then
                infiniteBait()
            end
            if Features.AntiReport then
                antiReport()
            end
            if Features.FishESP then
                setupFishESP()
            end
            visualEffects()
        end)
        wait(0.5)
    end
end)

