-- TELEPORT
local TPLocs = {}

local function updateTP()
    TPLocs = {}
    for i, sp in ipairs(GD.spots) do
        pcall(function()
            local cf
            if sp:IsA("Model") then cf = sp:GetBoundingBox()
            elseif sp:IsA("BasePart") then cf = sp.CFrame end
            if cf then TPLocs["Spot " .. i] = cf + Vector3.new(0, 3, 0) end
        end)
    end
    local function addLoc(name, obj)
        if not obj then return end
        pcall(function()
            local cf
            if obj:IsA("Model") then cf = obj:GetBoundingBox()
            elseif obj:IsA("BasePart") then cf = obj.CFrame end
            if cf then TPLocs[name] = cf + Vector3.new(0, 3, 0) end
        end)
    end
    addLoc("Shop", GD.shop)
    addLoc("Sell/Jual", GD.sell)
    addLoc("Event", GD.event)
    addLoc("Spawn", GD.spawn)
    for i, sp in ipairs(GD.secrets) do addLoc("Secret " .. i, sp) end
end

function F.tp(name)
    updateTP()
    if TPLocs[name] then
        Util.teleportTo(TPLocs[name])
        Util.notify("TP", "→ " .. name, 2)
    else
        Util.notify("TP", "Not found: " .. name, 2)
    end
end

-- AUTO FARM ROUTE
function F.autoRoute(on)
    S.autoRoute = on
    if not on then Util.notify("Farm Route", "OFF", 2); return end
    Util.notify("Farm Route", "ON", 2)

    task.spawn(function()
        updateTP()
        local route = {}
        for n, cf in pairs(TPLocs) do
            if string.find(n, "Spot") or string.find(n, "Secret") then
                table.insert(route, {name = n, cf = cf})
            end
        end

        if #route == 0 then
            Util.notify("Farm", "No spots!", 3)
            S.autoRoute = false
            return
        end

        local idx = 1
        while S.autoRoute do
            pcall(function()
                local sp = route[idx]
                if sp then
                    Util.notify("Farm", "→ " .. sp.name, 2)
                    Util.teleportTo(sp.cf)
                    Util.wait(1, 2)

                    local dur = math.random(30, 60)
                    local st = tick()
                    while S.autoRoute and (tick() - st) < dur do
                        if GD.remotes.cast then
                            Util.fireRemote(GD.remotes.cast)
                            Util.wait(1, 3)
                            local cr = GD.remotes.catch or GD.remotes.reel
                            if cr then Util.fireRemote(cr, "Perfect", 1, true) end
                        end
                        Util.wait(1, 3)
                    end
                end

                idx = idx + 1
                if idx > #route then
                    idx = 1
                    if GD.remotes.sell then Util.fireRemote(GD.remotes.sell, "All") end
                end
            end)
        end
    end)
end

