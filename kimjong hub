-- Fish ESP
local _esp_objects = {
    fish = {},
    player = {},
    item = {},
    npc = {},
    treasure = {},
}

local function _createESP(obj, color, text, category)
    pcall(function()
        -- BillboardGui ESP
        local _bb = Instance.new("BillboardGui")
        _bb.Name = "_kj_esp_" .. category
        _bb.AlwaysOnTop = true
        _bb.Size = UDim2.new(0, 200, 0, 50)
        _bb.StudsOffset = Vector3.new(0, 3, 0)

        local _tl = Instance.new("TextLabel")
        _tl.BackgroundTransparency = 0.5
        _tl.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        _tl.Size = UDim2.new(1, 0, 1, 0)
        _tl.Text = text
        _tl.TextColor3 = color
        _tl.TextScaled = true
        _tl.Font = Enum.Font.GothamBold
        _tl.Parent = _bb

        local _target = obj
        if obj:IsA("Model") then
            _target = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart") or obj.PrimaryPart
        end

        if _target then
            _bb.Adornee = _target
            _bb.Parent = _target

            -- Highlight
            local _hl = Instance.new("Highlight")
            _hl.Name = "_kj_hl_" .. category
            _hl.FillColor = color
            _hl.FillTransparency = 0.7
            _hl.OutlineColor = color
            _hl.OutlineTransparency = 0.3
            _hl.Parent = obj

            table.insert(_esp_objects[category], {bb = _bb, hl = _hl, obj = obj})
        end
    end)
end

local function _clearESP(category)
    if _esp_objects[category] then
        for _, _data in ipairs(_esp_objects[category]) do
            pcall(function() _data.bb:Destroy() end)
            pcall(function() _data.hl:Destroy() end)
        end
        _esp_objects[category] = {}
    end
end

