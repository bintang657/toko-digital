local function _analyze_game()
    -- Scan all remotes
    pcall(function()
        local _remote_folders = {_RS}

        -- Check common remote storage locations
        local _common_paths = {
            _RS:FindFirstChild("Remotes"),
            _RS:FindFirstChild("Events"),
            _RS:FindFirstChild("Network"),
            _RS:FindFirstChild("Communication"),
            _RS:FindFirstChild("Remote"),
            _RS:FindFirstChild("Shared"),
        }

        for _, _f in ipairs(_common_paths) do
            if _f then table.insert(_remote_folders, _f) end
        end

        for _, _folder in ipairs(_remote_folders) do
            for _, _obj in ipairs(_folder:GetDescendants()) do
                if _obj:IsA(_STR._re) or _obj:IsA(_STR._rf) then
                    local _n = _obj.Name:lower()

                    if string.find(_n, "cast") or string.find(_n, "throw") or string.find(_n, "rod") then
                        _GameData.remotes.cast = _obj
                    elseif string.find(_n, "catch") or string.find(_n, "grab") or string.find(_n, "hook") then
                        _GameData.remotes.catch = _obj
                    elseif string.find(_n, "reel") or string.find(_n, "pull") then
                        _GameData.remotes.reel = _obj
                    elseif string.find(_n, "sell") then
                        _GameData.remotes.sell = _obj
                    elseif string.find(_n, "buy") or string.find(_n, "purchase") then
                        _GameData.remotes.buy = _obj
                    elseif string.find(_n, "equip") then
                        _GameData.remotes.equip = _obj
                    elseif string.find(_n, "collect") or string.find(_n, "claim") or string.find(_n, "reward") then
                        _GameData.remotes.collect = _obj
                    elseif string.find(_n, "quest") or string.find(_n, "mission") then
                        _GameData.remotes.quest = _obj
                    elseif string.find(_n, "bait") then
                        _GameData.remotes.bait = _obj
                    elseif string.find(_n, "upgrade") then
                        _GameData.remotes.upgrade = _obj
                    elseif string.find(_n, "fish") and not string.find(_n, "anti") then
                        -- Could be fishing remote
                        if not _GameData.remotes.cast then
                            _GameData.remotes.cast = _obj
                        end
                    end
                end
            end
        end
    end)

    -- Scan workspace for locations and objects
    pcall(function()
        for _, _obj in ipairs(_WS:GetDescendants()) do
            local _n = _obj.Name:lower()

            -- Fishing spots
            if (string.find(_n, "fish") and string.find(_n, "spot")) or
               (string.find(_n, "fishing") and string.find(_n, "zone")) or
               string.find(_n, "fishingspot") or
               string.find(_n, "fishspot") or
               string.find(_n, "castzone") then
                table.insert(_GameData.locations.fishing_spots, _obj)
            end

            -- Shop
            if string.find(_n, "shop") or string.find(_n, "store") or string.find(_n, "toko") then
                if _obj:IsA("Model") or _obj:IsA("Part") or _obj:IsA("BasePart") then
                    _GameData.locations.shop = _obj
                end
            end

            -- Sell area
            if string.find(_n, "sell") and (string.find(_n, "area") or string.find(_n, "zone") or string.find(_n, "npc")) then
                _GameData.locations.sell_area = _obj
            end

            -- Event area
            if string.find(_n, "event") then
                if _obj:IsA("Model") or _obj:IsA("Part") then
                    _GameData.locations.event_area = _obj
                end
            end

            -- Secret spots
            if string.find(_n, "secret") or string.find(_n, "hidden") or string.find(_n, "rare") then
                if _obj:IsA("Model") or _obj:IsA("Part") then
                    table.insert(_GameData.locations.secret_spots, _obj)
                end
            end

            -- Fish models
            if string.find(_n, "fish") and (_obj:IsA("Model") or _obj:IsA("MeshPart")) then
                if _obj.Parent and not string.find(_obj.Parent.Name:lower(), "player") then
                    table.insert(_GameData.fish_models, _obj)
                end
            end

            -- NPCs
            if _obj:IsA("Model") and _obj:FindFirstChildOfClass("Humanoid") then
                if _obj ~= (_LP.Character) then
                    local _is_player = false
                    for _, _p in ipairs(_Players:GetPlayers()) do
                        if _p.Character == _obj then _is_player = true; break end
                    end
                    if not _is_player then
                        table.insert(_GameData.npcs, _obj)
                    end
                end
            end

            -- Treasures/Chests
            if string.find(_n, "chest") or string.find(_n, "treasure") or
               string.find(_n, "crate") or string.find(_n, "loot") then
                table.insert(_GameData.treasures, _obj)
            end
        end

        -- Get spawn location
        local _spawn = _WS:FindFirstChild("SpawnLocation") or _WS:FindFirstChild("Spawn")
        if _spawn then
            _GameData.locations.spawn = _spawn
        end
    end)

    _GameData.analyzed = true
end

