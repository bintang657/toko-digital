    if C[name] then pcall(function() C[name]:Disconnect() end); C[name] = nil end
end

-- ======================================
-- ESP SYSTEM
-- ======================================
local ESP = {fish={}, player={}, item={}, npc={}, chest={}}

local function makeESP(obj, color, text, cat)
    pcall(function()
        local target = obj
        if obj:IsA("Model") then
            target = obj.PrimaryPart
                or obj:FindFirstChild("HumanoidRootPart")
                or obj:FindFirstChildWhichIsA("BasePart")
        end
        if not target or not target:IsA("BasePart") then return end

        local bb = Instance.new("BillboardGui")
        bb.Name = "_kjesp"
        bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0, 180, 0, 40)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.Adornee = target
        bb.Parent = target

        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 0.4
        tl.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.Text = text
        tl.TextColor3 = color
        tl.TextScaled = true
        tl.Font = Enum.Font.GothamBold
        tl.Parent = bb

        pcall(function()
            Instance.new("UICorner", tl).CornerRadius = UDim.new(0, 4)
        end)

        local hl = Instance.new("Highlight")
        hl.Name = "_kjhl"
        hl.FillColor = color
        hl.FillTransparency = 0.7
        hl.OutlineColor = color
        hl.OutlineTransparency = 0.3
        hl.Parent = obj

        table.insert(ESP[cat], {bb=bb, hl=hl})
    end)
end

local function clearESP(cat)
    if not ESP[cat] then return end
    for _, d in ipairs(ESP[cat]) do
        pcall(function() d.bb:Destroy() end)
        pcall(function() d.hl:Destroy() end)
    end
    ESP[cat] = {}
end

