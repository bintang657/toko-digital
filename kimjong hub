-- Auto Farm Route
_Features.autoFarmRoute = function(enabled)
    _States.auto_farm_route = enabled

    if enabled then
        _Util.notify("Auto Farm", "Auto Farm Route ENABLED", 2)
        task.spawn(function()
            _updateTeleportLocations()
            local _route = {}

            -- Build route from available fishing spots
            for _name, _cf in pairs(_TeleportLocations) do
                if string.find(_name, "Fishing") or string.find(_name, "Secret") then
                    table.insert(_route, {name = _name, cf = _cf})
                end
            end

            if #_route == 0 then
                _Util.notify("Auto Farm", "No fishing spots found!", 3)
                _States.auto_farm_route = false
                return
            end

            local _idx = 1
            while _States.auto_farm_route do
                pcall(function()
                    local _spot = _route[_idx]
                    if _spot and typeof(_spot.cf) == "CFrame" then
                        _Util.notify("Auto Farm", "Going to " .. _spot.name, 2)
                        _Util.teleportTo(_spot.cf)
                        _rnd_delay(1, 2)

                        -- Fish at this spot for a while
                        local _fish_time = math.random(30, 60)
                        local _start = tick()

                        while _States.auto_farm_route and (tick() - _start) < _fish_time do
                            -- Auto fish at current spot
                            if _GameData.remotes.cast then
                                _Util.fireRemote(_GameData.remotes.cast)
                                _rnd_delay(1, 3)
                                if _GameData.remotes.catch then
                                    _Util.fireRemote(_GameData.remotes.catch, "Perfect", 1, true)
                                end
                            end
                            _rnd_delay(1, 3)
                        end
                    end

                    _idx = _idx + 1
                    if _idx > #_route then
                        _idx = 1
                        -- Sell fish between cycles
                        if _GameData.remotes.sell then
                            _Util.fireRemote(_GameData.remotes.sell, "All")
                        end
                    end
                end)
            end
        end)
    else
        _Util.notify("Auto Farm", "Auto Farm Route DISABLED", 2)
    end
end

