-- SECTION 4: ANTI-CHEAT MODULE (Safe - skips unsupported)
-- ============================================================

local AntiCheat = {}
AntiCheat.enabled = true
AntiCheat.spoofedSpeed = 16
AntiCheat.realSpeed = 16
AntiCheat.spoofedJump = 50
AntiCheat.realJump = 50
AntiCheat.blockedRemotes = {}
AntiCheat.hooksInstalled = false

function AntiCheat.init()
    local results = {
        namecall = false,
        index = false,
        kickBlock = false,
        acScan = false,
    }

    -- Hook __namecall (ONLY if hookmetamethod exists)
    if _ENV.hookmetamethod and _ENV.getnamecallmethod then
        local ok, err = pcall(function()
            local oldNamecall
            oldNamecall = _ENV.hookmetamethod(game, "__namecall", _ENV.newcclosure(function(self, ...)
                local args = {...}
                local method = _ENV.getnamecallmethod()

                -- Block kick
                if method == STR.Kick and AntiCheat.enabled then
                    return
                end

                -- Block anti-cheat remotes
                if method == STR.FireServer or method == STR.InvokeServer then
                    local remoteName = ""
                    pcall(function() remoteName = self.Name end)
                    if AntiCheat.blockedRemotes[remoteName] then
                        return
                    end
                end

                return oldNamecall(self, ...)
            end))
            results.namecall = true
            AntiCheat.hooksInstalled = true
        end)
        if not ok then
            warn("[KimJong] Namecall hook failed (safe skip): " .. tostring(err))
        end
    else
        print("[KimJong] hookmetamethod not available - using alternative anti-kick")

        -- Alternative anti-kick: disconnect kick connections
        pcall(function()
            if _ENV.getconnections then
                local connections = _ENV.getconnections(LP.OnTeleport)
                for _, conn in ipairs(connections) do
                    pcall(function() conn:Disable() end)
                end
            end
        end)
        results.kickBlock = true
    end

    -- Scan for anti-cheat remotes
    pcall(function()
        local function scanFolder(folder)
            if not folder then return end
            for _, child in ipairs(folder:GetDescendants()) do
                pcall(function()
                    if child:IsA(STR.RemoteEvent) or child:IsA(STR.RemoteFunction) then
                        local n = child.Name:lower()
                        if string.find(n, "anti") or string.find(n, "cheat") or
                           string.find(n, "detect") or string.find(n, "security") or
                           string.find(n, "integrity") or string.find(n, "report") or
                           string.find(n, "validation") then
                            AntiCheat.blockedRemotes[child.Name] = true
                        end
                    end
                end)
            end
        end
        scanFolder(RS)
        pcall(function() scanFolder(game:GetService("ReplicatedFirst")) end)
        results.acScan = true
    end)

    -- Disconnect suspicious RenderStepped connections
    if _ENV.getconnections then
        pcall(function()
            local conns = _ENV.getconnections(RunService.RenderStepped)
            for _, c in ipairs(conns) do
                pcall(function()
                    if c.Function and _ENV.getinfo then
                        local info = _ENV.getinfo(c.Function)
                        local src = info and info.source or ""
                        if string.find(src:lower(), "anti") or
                           string.find(src:lower(), "cheat") or
                           string.find(src:lower(), "detect") then
                            c:Disable()
                        end
                    end
                end)
            end
        end)
    end

    return results
end

