-- ANTI-CHEAT (Safe untuk Delta)
-- ======================================
local AC = {
    enabled = true,
    blocked = {},
    hooked = false,
    realSpeed = 16,
    realJump = 50,
}

function AC.init()
    -- Scan anti-cheat remotes
    pcall(function()
        for _, obj in ipairs(RS:GetDescendants()) do
            pcall(function()
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    local n = obj.Name:lower()
                    if string.find(n, "anti") or string.find(n, "cheat") or
                       string.find(n, "detect") or string.find(n, "security") or
                       string.find(n, "integrity") or string.find(n, "report") or
                       string.find(n, "valid") then
                        AC.blocked[obj.Name] = true
                    end
                end
            end)
        end
    end)

    -- Hook namecall ONLY jika tersedia
    if Exec.hookmetamethod and Exec.getnamecallmethod then
        pcall(function()
            local oldNC
            oldNC = Exec.hookmetamethod(game, "__namecall",
                (Exec.newcclosure or function(f) return f end)(function(self, ...)
                    local method = Exec.getnamecallmethod()

                    -- Block kick
                    if method == "Kick" and AC.enabled then
                        return
                    end

                    -- Block AC remotes
                    if method == "FireServer" or method == "InvokeServer" then
                        local rn = ""
                        pcall(function() rn = self.Name end)
                        if AC.blocked[rn] then
                            return
                        end
                    end

                    return oldNC(self, ...)
                end)
            )
            AC.hooked = true
        end)
    end

    local blockedCount = 0
    for _ in pairs(AC.blocked) do blockedCount = blockedCount + 1 end
    print("[KimJong] AC blocked remotes: " .. blockedCount)
    print("[KimJong] Hooks installed: " .. tostring(AC.hooked))
end

-- ======================================
-- GAME DATA SCANNER
-- ======================================
local GD = {
    remotes = {},
    spots = {},
    shop = nil,
    sell = nil,
    event = nil,
    secrets = {},
    spawn = nil,
    npcs = {},
    chests = {},
}

function GD.scan()
    print("[KimJong] Scanning game...")

    -- Scan semua remote di RS
    pcall(function()
        local keywords = {
            cast = {"cast", "throw", "fish", "rod", "start", "mulai", "lempar", "mancing"},
            catch = {"catch", "hook", "tangkap", "complete", "finish", "hasil"},
            reel = {"reel", "pull", "tarik", "drag"},
            sell = {"sell", "jual", "vendor"},
            buy = {"buy", "beli", "purchase", "shop", "toko"},
            equip = {"equip", "pakai", "select", "use", "wear"},
            collect = {"collect", "claim", "reward", "ambil", "hadiah", "pickup"},
            quest = {"quest", "mission", "misi", "task", "tugas"},
            bait = {"bait", "umpan", "lure"},
            upgrade = {"upgrade", "tingkat", "enhance", "level"},
        }

        -- Scan RS and subfolders
        for _, obj in ipairs(RS:GetDescendants()) do
            pcall(function()
                if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) and
                   not AC.blocked[obj.Name] then
                    local n = obj.Name:lower()
                    for cat, kws in pairs(keywords) do
                        if not GD.remotes[cat] then
                            for _, kw in ipairs(kws) do
                                if string.find(n, kw) then
                                    GD.remotes[cat] = obj
                                    print("  Remote [" .. cat .. "]: " .. obj.Name)
                                    break
                                end
                            end
                        end
                        if GD.remotes[cat] then break end
                    end
                end
            end)
        end
    end)

    -- Scan workspace
    pcall(function()
        for _, obj in ipairs(WS:GetDescendants()) do
            pcall(function()
                local n = obj.Name:lower()

                -- Fishing spots
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    if (string.find(n, "fish") and (string.find(n, "spot") or string.find(n, "zone") or string.find(n, "area")))
                       or string.find(n, "mancing") or string.find(n, "pancing")
                       or string.find(n, "castzone") then
                        table.insert(GD.spots, obj)
                    end
                end

                -- Shop
                if not GD.shop and (obj:IsA("Model") or obj:IsA("BasePart")) then
                    if string.find(n, "shop") or string.find(n, "toko") or string.find(n, "store") then
                        GD.shop = obj
                    end
                end

                -- Sell
                if not GD.sell and (obj:IsA("Model") or obj:IsA("BasePart")) then
                    if string.find(n, "sell") or string.find(n, "jual") then
                        GD.sell = obj
                    end
                end

                -- Event
                if not GD.event and (obj:IsA("Model") or obj:IsA("BasePart")) then
                    if string.find(n, "event") then
                        GD.event = obj
                    end
                end

                -- Secrets
                if (string.find(n, "secret") or string.find(n, "hidden") or string.find(n, "rahasia")) then
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        table.insert(GD.secrets, obj)
                    end
                end

                -- NPCs
                if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
                    local isP = false
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.Character == obj then isP = true; break end
                    end
                    if not isP and obj ~= LP.Character then
                        table.insert(GD.npcs, obj)
                    end
                end

                -- Chests
                if (string.find(n, "chest") or string.find(n, "treasure") or
                    string.find(n, "crate") or string.find(n, "peti")) then
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        table.insert(GD.chests, obj)
                    end
                end
            end)
        end

        -- Spawn
        pcall(function()
            GD.spawn = WS:FindFirstChild("SpawnLocation") or WS:FindFirstChild("Spawn")
        end)
    end)

    local rc = 0
    for _ in pairs(GD.remotes) do rc = rc + 1 end
    print("[KimJong] Scan done: " .. rc .. " remotes, " ..
          #GD.spots .. " spots, " .. #GD.npcs .. " NPCs, " ..
          #GD.chests .. " chests")
end

