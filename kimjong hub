-- Teleport locations builder
local TeleportLocations = {}

local function updateTeleportLocations()
    TeleportLocations = {}

    for i, spot in ipairs(GameData.locations.fishingSpots) do
        pcall(function()
            local cf
            if spot:IsA("Model") then
                cf = spot:GetBoundingBox()
            elseif spot:IsA("BasePart") then
                cf = spot.CFrame
            end
            if cf then
                TeleportLocations["Fishing Spot " .. i] = cf + Vector3.new(0, 3, 0)
            end
        end)
    end

    local function addLocation(name, obj)
        if not obj then return end
        pcall(function()
            local cf
            if obj:IsA("Model") then
                cf = obj:GetBoundingBox()
            elseif obj:IsA("BasePart") then
                cf = obj.CFrame
            end
            if cf then
                TeleportLocations[name] = cf + Vector3.new(0, 3, 0)
            end
        end)
    end

    addLocation("Shop", GameData.locations.shop)
    addLocation("Sell Area", GameData.locations.sellArea)
    addLocation("Event Area", GameData.locations.eventArea)
    addLocation("Spawn", GameData.locations.spawn)

    for i, spot in ipairs(GameData.locations.secretSpots) do
        addLocation("Secret Spot " .. i, spot)
    end
end

function Features.teleportTo(locationName)
    updateTeleportLocations()
    local cf = TeleportLocations[locationName]
    if cf and typeof(cf) == "CFrame" then
        Util.teleportTo(cf)
        Util.notify("Teleport", "→ " .. locationName, 2)
    else
        Util.notify("Teleport", "Location not found: " .. locationName, 3)
    end
end

function Features.autoFarmRoute(enabled)
    States.autoFarmRoute = enabled
    if not enabled then
        Util.notify("Auto Farm", "DISABLED", 2)
        return
    end

    Util.notify("Auto Farm", "ENABLED", 2)
    task.spawn(function()
        updateTeleportLocations()
        local route = {}
        for name, cf in pairs(TeleportLocations) do
            if string.find(name, "Fishing") or string.find(name, "Secret") then
                table.insert(route, {name = name, cf = cf})
            end
        end

        if #route == 0 then
            Util.notify("Auto Farm", "No fishing spots found!", 3)
            States.autoFarmRoute = false
            return
        end

        local idx = 1
        while States.autoFarmRoute do
            pcall(function()
                local spot = route[idx]
                if spot and typeof(spot.cf) == "CFrame" then
                    Util.notify("Auto Farm", "→ " .. spot.name, 2)
                    Util.teleportTo(spot.cf)
                    Util.randomDelay(1, 2)

                    -- Fish at spot
                    local fishTime = math.random(30, 60)
                    local startTime = tick()

                    while States.autoFarmRoute and (tick() - startTime) < fishTime do
                        if GameData.remotes.cast then
                            Util.fireRemote(GameData.remotes.cast)
                            Util.randomDelay(1, 3)
                            local catchR = GameData.remotes.catch or GameData.remotes.reel
                            if catchR then
                                Util.fireRemote(catchR, "Perfect", 1, true)
                            end
                        end
                        Util.randomDelay(1, 3)
                    end
                end

                idx = idx + 1
                if idx > #route then
                    idx = 1
                    if GameData.remotes.sell then
                        Util.fireRemote(GameData.remotes.sell, "All")
                    end
                end
            end)
        end
    end)
end

