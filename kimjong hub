-- Helper to toggle feature
local function setFeature(name, state)
    Features[name] = state
    if state then
        -- start the feature logic
        if name == "autoFish" then
            Toggles.autoFish = task.spawn(function()
                while Features.autoFish do
                    local castRemotes = Utility.findRemote("cast")
                    if #castRemotes > 0 then
                        pcall(function() castRemotes[1]:FireServer() end)
                    end
                    Utility.delayedWait(1, 3)
                end
            end)
        elseif name == "autoReel" then
            Toggles.autoReel = task.spawn(function()
                while Features.autoReel do
                    -- find reel remote and fire
                    local reelRemotes = Utility.findRemote("reel")
                    if #reelRemotes > 0 then
                        pcall(function() reelRemotes[1]:FireServer() end)
                    end
                    Utility.delayedWait(0.2, 0.8)
                end
            end)
        elseif name == "autoPerfect" then
            -- hook into the perfect catch remote
            Toggles.autoPerfect = task.spawn(function()
                while Features.autoPerfect do
                    local perfectRemotes = Utility.findRemote("perfect")
                    if #perfectRemotes > 0 then
                        pcall(function() perfectRemotes[1]:FireServer() end)
                    end
                    Utility.delayedWait(0.1, 0.3)
                end
            end)
        elseif name == "instantFish" then
            Toggles.instantFish = task.spawn(function()
                while Features.instantFish do
                    -- simulate instant catch
                    local catchRemotes = Utility.findRemote("catch")
                    if #catchRemotes > 0 then
                        pcall(function() catchRemotes[1]:FireServer() end)
                    end
                    Utility.delayedWait(0.5, 1)
                end
            end)
        elseif name == "autoSell" then
            Toggles.autoSell = task.spawn(function()
                while Features.autoSell do
                    -- find sell remote
                    local sellRemotes = Utility.findRemote("sell")
                    if #sellRemotes > 0 then
                        pcall(function() sellRemotes[1]:FireServer() end)
                    end
                    Utility.delayedWait(2, 5)
                end
            end)
        elseif name == "speedHack" then
            local char = Utility.getChar()
            local humanoid = char and char:FindFirstChild("Humanoid")
            if humanoid then
                Toggles.speedHack = game:GetService("RunService").Heartbeat:Connect(function()
                    if Features.speedHack and humanoid then
                        humanoid.WalkSpeed = Features.speedValue
                    elseif not Features.speedHack and humanoid then
                        humanoid.WalkSpeed = 16
                    end
                end)
            end
        elseif name == "flyHack" then
            Toggles.flyHack = task.spawn(function()
                local flying = false
                local bodyVelocity = nil
                local char = Utility.getChar()
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                while Features.flyHack do
                    if not flying then
                        flying = true
                        bodyVelocity = Instance.new("BodyVelocity")
                        bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
                        bodyVelocity.Velocity = Vector3.new(0,0,0)
                        bodyVelocity.Parent = hrp
                    end
                    local move = Vector3.new()
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0,0,-1) end
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0,0,1) end
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1,0,0) end
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1,0,0) end
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0,1,0) end
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftControl) then move = move + Vector3.new(0,-1,0) end
                    move = move.Unit * 50
                    if bodyVelocity then bodyVelocity.Velocity = move end
                    task.wait()
                end
                if bodyVelocity then bodyVelocity:Destroy() end
            end)
        elseif name == "noclip" then
            Toggles.noclip = game:GetService("RunService").Stepped:Connect(function()
                if Features.noclip then
                    local char = Utility.getChar()
                    for _, part in ipairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                else
                    local char = Utility.getChar()
                    for _, part in ipairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = true
                        end
                    end
                end
            end)
        elseif name == "infiniteJump" then
            Toggles.infiniteJump = game:GetService("UserInputService").JumpRequest:Connect(function()
                if Features.infiniteJump then
                    local char = Utility.getChar()
                    local humanoid = char and char:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end
            end)
        elseif name == "fullbright" then
            local lighting = game:GetService("Lighting")
            if Features.fullbright then
                lighting.Brightness = 2
                lighting.ClockTime = 12
                lighting.FogEnd = 100000
            else
                lighting.Brightness = 1
                lighting.FogEnd = 1000
            end
        elseif name == "noFog" then
            local lighting = game:GetService("Lighting")
            if Features.noFog then
                lighting.FogEnd = 100000
            else
                lighting.FogEnd = 1000
            end
        elseif name == "noWaterEffect" then
            -- search for water parts and set transparency
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Part") and v.Name:lower():find("water") then
                    v.Transparency = 1
                end
            end
        elseif name == "antiAFK" then
            Toggles.antiAFK = game:GetService("RunService").Heartbeat:Connect(function()
                if Features.antiAFK then
                    local hrp = Utility.getChar() and Utility.getChar():FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.Velocity = hrp.Velocity + Vector3.new(0, 0.01, 0)
                    end
                end
            end)
        elseif name == "godMode" then
            Toggles.godMode = game:GetService("RunService").Heartbeat:Connect(function()
                if Features.godMode then
                    local char = Utility.getChar()
                    local humanoid = char and char:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid.MaxHealth = 1e9
                        humanoid.Health = 1e9
                    end
                end
            end)
        elseif name == "fpsBooster" then
            if Features.fpsBooster then
                -- remove unnecessary decorations
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("Decal") or v:IsA("ParticleEmitter") then
                        v:Destroy()
                    end
                end
            end
        elseif name == "screenshotMode" then
            if Features.screenshotMode then
                -- hide UI
                if UI then UI.Visible = false end
            else
                if UI then UI.Visible = true end
            end
        elseif name == "chatSpam" then
            Toggles.chatSpam = task.spawn(function()
                while Features.chatSpam do
                    if Features.spamMessage ~= "" then
                        local chat = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
                        if chat then
                            local sayMsg = chat:FindFirstChild("SayMessageRequest")
                            if sayMsg then
                                sayMsg:FireServer(Features.spamMessage, "All")
                            end
                        end
                    end
                    task.wait(1)
                end
            end)
        end
    else
        -- stop feature
        if Toggles[name] then
            if type(Toggles[name]) == "thread" then
                coroutine.close(Toggles[name])
            elseif Toggles[name].Disconnect then
                Toggles[name]:Disconnect()
            end
            Toggles[name] = nil
        end
        -- additional cleanup for some features
        if name == "speedHack" then
            local char = Utility.getChar()
            local humanoid = char and char:FindFirstChild("Humanoid")
            if humanoid then humanoid.WalkSpeed = 16 end
        elseif name == "flyHack" then
            local char = Utility.getChar()
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local bv = hrp:FindFirstChildOfClass("BodyVelocity")
                if bv then bv:Destroy() end
            end
        elseif name == "noclip" then
            local char = Utility.getChar()
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end

