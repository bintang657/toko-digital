local _Util = {}

-- Safe character/humanoid getter
function _Util.getCharacter()
    local _ok, _char = pcall(function()
        return _LP.Character or _LP.CharacterAdded:Wait()
    end)
    return _ok and _char or nil
end

function _Util.getHumanoid()
    local _char = _Util.getCharacter()
    if _char then
        return _char:FindFirstChildOfClass(_STR._hm)
    end
    return nil
end

function _Util.getHRP()
    local _char = _Util.getCharacter()
    if _char then
        return _char:FindFirstChild(_STR._hrp)
    end
    return nil
end

-- Safe remote finder
function _Util.findRemote(name, parent)
    parent = parent or _RS
    local _result = nil
    pcall(function()
        -- Search by exact name
        _result = parent:FindFirstChild(name, true)
    end)
    if not _result then
        pcall(function()
            -- Search by partial match
            for _, _d in ipairs(parent:GetDescendants()) do
                if (_d:IsA(_STR._re) or _d:IsA(_STR._rf)) and
                   string.find(_d.Name:lower(), name:lower()) then
                    _result = _d
                    break
                end
            end
        end)
    end
    return _result
end

-- Safe remote fire
function _Util.fireRemote(remote, ...)
    if not remote then return false end
    local _ok, _err = pcall(function()
        _rnd_delay(0.05, 0.2)
        if remote:IsA(_STR._re) then
            remote:FireServer(...)
        elseif remote:IsA(_STR._rf) then
            return remote:InvokeServer(...)
        end
    end)
    return _ok
end

-- Teleport with tween (less suspicious)
function _Util.tweenTo(target_cf, speed)
    speed = speed or 100
    local _hrp = _Util.getHRP()
    if not _hrp then return false end

    local _dist = (_hrp.Position - target_cf.Position).Magnitude
    local _time = _dist / speed

    if _time < 0.1 then _time = 0.1 end
    if _time > 15 then _time = 15 end

    local _tween_info = TweenInfo.new(_time, Enum.EasingStyle.Linear)
    local _tween = _TS:Create(_hrp, _tween_info, {CFrame = target_cf})
    _tween:Play()
    _tween.Completed:Wait()
    return true
end

-- Instant teleport
function _Util.teleportTo(target_cf)
    local _hrp = _Util.getHRP()
    if not _hrp then return false end
    pcall(function()
        _hrp.CFrame = target_cf
    end)
    return true
end

-- Notification
function _Util.notify(title, text, duration)
    pcall(function()
        _SG:SetCore("SendNotification", {
            Title = title or "Script KimJong",
            Text = text or "",
            Duration = duration or 3,
        })
    end)
end

-- Find game objects
function _Util.findInWorkspace(name, class)
    local _results = {}
    pcall(function()
        for _, _obj in ipairs(_WS:GetDescendants()) do
            local _match = true
            if name then
                _match = _match and (string.find(_obj.Name:lower(), name:lower()) ~= nil)
            end
            if class then
                _match = _match and _obj:IsA(class)
            end
            if _match then
                table.insert(_results, _obj)
            end
        end
    end)
    return _results
end

