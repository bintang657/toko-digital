local Utilities = {}

--- Safe pcall wrapper dengan error logging
---@param funcName string Nama fungsi untuk logging
---@param func function Fungsi yang akan dijalankan
---@param ... any Argumen tambahan
---@return boolean, any
function Utilities.SafeCall(funcName, func, ...)
    local success, result = pcall(func, ...)
    if not success then
        warn(string.format("[kimjong sc] Error di %s: %s", funcName, tostring(result)))
    end
    return success, result
end

--- Teleport karakter ke posisi CFrame tertentu
---@param targetCFrame CFrame Posisi tujuan
function Utilities.TeleportTo(targetCFrame)
