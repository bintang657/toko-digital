                    or Utilities.FindRemote("sell")
                    or Utilities.FindRemote("SellFish")
                    or Utilities.FindRemote("SellAll")
                    or Utilities.FindRemote("SellInventory")

                if sellRemote then
                    if sellRemote:IsA("RemoteEvent") then
                        sellRemote:FireServer("All") -- Parameter umum
                        sellRemote:FireServer()
                    elseif sellRemote:IsA("RemoteFunction") then
                        sellRemote:InvokeServer("All")
                    end
                end

                -- Metode 2: Teleport ke NPC Merchant dan trigger proximity prompt
                local merchantNPC = nil
                for _, npc in ipairs(Workspace:GetDescendants()) do
                    if npc:IsA("Model") or npc:IsA("Part") then
                        local nameLower = npc.Name:lower()
                        if nameLower:find("merchant") or nameLower:find("sell")
                           or nameLower:find("shop") or nameLower:find("vendor") then
                            merchantNPC = npc
                            break
                        end
                    end
                end

                if merchantNPC then
                    -- Trigger ProximityPrompt jika ada
                    local prompt = merchantNPC:FindFirstChildOfClass("ProximityPrompt")
                    if not prompt then
                        prompt = merchantNPC:FindFirstChild("ProximityPrompt", true)
                    end
                    if prompt then
                        fireproximityprompt(prompt)
