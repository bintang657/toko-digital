-- 3E. FISH ESP MODULE
-- ───────────────────────────────────────────────────────────
function Features.StartFishESP()
    if State.LoopRunning.FishESP then return end
    State.LoopRunning.FishESP = true

    task.spawn(function()
        while State.FishESP and State.LoopRunning.FishESP do
            Utilities.SafeCall("FishESP_Loop", function()
                -- Cari container ikan di workspace
                local fishContainers = {}

                -- Strategi: cari folder/model yang berisi ikan
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    local nameLower = obj.Name:lower()
                    local isFish = nameLower:find("fish") or nameLower:find("ikan")
                        or nameLower:find("catch") or nameLower:find("spawn")
                        or nameLower:find("bobber") or nameLower:find("node")

                    if isFish and (obj:IsA("Model") or obj:IsA("Part") or obj:IsA("MeshPart")) then
                        -- Pastikan belum punya ESP
                        if not obj:FindFirstChild("KimJongESP") then
                            local position = nil
                            if obj:IsA("Model") and obj.PrimaryPart then
                                position = obj.PrimaryPart.Position
                            elseif obj:IsA("BasePart") then
                                position = obj.Position
                            end

                            if position then
                                local distance = Utilities.GetDistance(position)
                                local displayName = obj.Name
                                local espText = string.format(
                                    "🐟 %s\n[%.0f studs]",
                                    displayName, distance
                                )
                                Utilities.CreateESP(
                                    obj, espText,
                                    Color3.fromRGB(0, 200, 255), -- Cyan
                                    "Fish"
                                )
                            end
                        else
                            -- Update jarak pada ESP yang sudah ada
                            local billboard = obj:FindFirstChild("KimJongESP")
                            if billboard then
                                local label = billboard:FindFirstChild("ESPLabel")
                                if label then
                                    local position = obj:IsA("Model")
                                        and obj.PrimaryPart
                                        and obj.PrimaryPart.Position
                                        or obj:IsA("BasePart")
                                        and obj.Position
                                    if position then
                                        local dist = Utilities.GetDistance(position)
                                        label.Text = string.format(
                                            "🐟 %s\n[%.0f studs]",
                                            obj.Name, dist
                                        )
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait(1) -- Refresh ESP setiap 1 detik
        end

        -- Cleanup saat dimatikan
        Utilities.ClearESP("Fish")
        State.LoopRunning.FishESP = false
    end)
end

function Features.StopFishESP()
    State.LoopRunning.FishESP = false
    Utilities.ClearESP("Fish")
end
