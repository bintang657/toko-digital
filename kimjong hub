local _ENV = {}

-- Safe function checker - returns function or nil WITHOUT error
local function _safeGet(name)
    local ok, result = pcall(function()
        return getfenv()[name]
    end)
    if ok and result and type(result) == "function" then
        return result
    end
    -- Try global
    ok, result = pcall(function()
        return _G[name]
    end)
    if ok and result and type(result) == "function" then
        return result
    end
    return nil
end

