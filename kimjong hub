-- Hook __namecall untuk intercept remote calls
local function _setup_namecall_hook()
    if not _ENV_CHECK._hm then
        warn("[KimJong] hookmetamethod not available, skipping namecall hook")
        return false
    end

    local _old_nc
    _old_nc = hookmetamethod(game, _STR._nc, _ENV_CHECK._nc(function(self, ...)
        local _args = {...}
        local _method = getnamecallmethod()

        -- Anti-Kick bypass
        if _method == _STR._k then
            if _AC_Module._enabled then
                return -- Block kick
            end
        end

        -- Remote spoofing
        if _method == _STR._fs or _method == _STR._is then
            local _remote_name = ""
            pcall(function() _remote_name = self.Name end)

            -- Block anti-cheat remotes
            if _AC_Module._blocked_remotes[_remote_name] then
                return
            end

            -- Spoof speed/position related remotes
            if _AC_Module._enabled then
                for _i, _v in ipairs(_args) do
                    if type(_v) == "number" then
                        -- Spoof walkspeed values
                        if _v == _AC_Module._real_speed and _AC_Module._real_speed ~= 16 then
                            _args[_i] = _AC_Module._spoofed_speed
                        end
                    elseif typeof(_v) == "CFrame" and _AC_Module._ghost_pos then
                        -- Spoof position
                        _args[_i] = _AC_Module._ghost_pos
                    elseif typeof(_v) == "Vector3" and _AC_Module._ghost_pos then
                        _args[_i] = _AC_Module._ghost_pos.Position
                    end
                end
            end

            -- Log intercepted calls for analysis
            if #_AC_Module._intercepted < 500 then
                table.insert(_AC_Module._intercepted, {
                    name = _remote_name,
                    method = _method,
                    time = tick()
                })
            end

            return _old_nc(self, unpack(_args))
        end

        return _old_nc(self, ...)
    end))

    _AC_Module._originals["namecall"] = _old_nc
    return true
end

-- Hook __index untuk spoof Humanoid properties
local function _setup_index_hook()
    if not _ENV_CHECK._hm then return false end

    local _old_idx
    _old_idx = hookmetamethod(game, _STR._idx, _ENV_CHECK._nc(function(self, key)
        if _AC_Module._enabled then
            -- Spoof WalkSpeed reading
            if key == _STR._ws then
                local _ok, _cls = pcall(function() return self.ClassName end)
                if _ok and _cls == _STR._hm then
                    if checkcaller and not checkcaller() then
                        return _AC_Module._spoofed_speed
                    end
                end
            end

            -- Spoof JumpPower reading
            if key == _STR._jp then
                local _ok, _cls = pcall(function() return self.ClassName end)
                if _ok and _cls == _STR._hm then
                    if checkcaller and not checkcaller() then
                        return _AC_Module._spoofed_jump
                    end
                end
            end
        end

        return _old_idx(self, key)
    end))

    _AC_Module._originals["index"] = _old_idx
    return true
end

-- Hook __newindex untuk intercept property changes dari anti-cheat
local function _setup_newindex_hook()
    if not _ENV_CHECK._hm then return false end

    local _old_nidx
    _old_nidx = hookmetamethod(game, _STR._nidx, _ENV_CHECK._nc(function(self, key, value)
        if _AC_Module._enabled then
            local _ok, _cls = pcall(function() return self.ClassName end)
            if _ok and _cls == _STR._hm then
                -- Prevent anti-cheat from resetting WalkSpeed
                if key == _STR._ws then
                    if checkcaller and not checkcaller() then
                        if value == 16 and _AC_Module._real_speed ~= 16 then
                            return _old_nidx(self, key, _AC_Module._real_speed)
                        end
                    end
                end
                -- Prevent anti-cheat from resetting JumpPower
                if key == _STR._jp then
                    if checkcaller and not checkcaller() then
                        if value == 50 and _AC_Module._real_jump ~= 50 then
                            return _old_nidx(self, key, _AC_Module._real_jump)
                        end
                    end
                end
            end
        end
        return _old_nidx(self, key, value)
    end))

    _AC_Module._originals["newindex"] = _old_nidx
    return true
end

-- Disconnect anti-cheat connections
local function _disconnect_ac_connections()
    if not _ENV_CHECK._gc2 then return false end

    pcall(function()
        -- Disconnect RenderStepped anti-cheat checks
        local _conns = getconnections(_RunS.RenderStepped)
        for _, _c in ipairs(_conns) do
            pcall(function()
                if _c.Function then
                    local _info = getinfo and getinfo(_c.Function) or nil
                    if _info then
                        local _src = _info.source or ""
                        -- Disconnect suspicious anti-cheat connections
                        if string.find(_src, "anti") or
                           string.find(_src, "cheat") or
                           string.find(_src, "detect") or
                           string.find(_src, "security") or
                           string.find(_src, "validation") then
                            _c:Disable()
                        end
                    end
                end
            end)
        end

        -- Same for Heartbeat
        local _hb_conns = getconnections(_RunS.Heartbeat)
        for _, _c in ipairs(_hb_conns) do
            pcall(function()
                if _c.Function then
                    local _info = getinfo and getinfo(_c.Function) or nil
                    if _info then
                        local _src = _info.source or ""
                        if string.find(_src, "anti") or
                           string.find(_src, "cheat") or
                           string.find(_src, "detect") then
                            _c:Disable()
                        end
                    end
                end
            end)
        end
    end)

    return true
end

-- Scan and block anti-cheat remotes
local function _scan_ac_remotes()
    pcall(function()
        local function _scan_folder(folder)
            for _, _child in ipairs(folder:GetDescendants()) do
                pcall(function()
                    if _child:IsA(_STR._re) or _child:IsA(_STR._rf) then
                        local _name = _child.Name:lower()
                        if string.find(_name, "anti") or
                           string.find(_name, "cheat") or
                           string.find(_name, "detect") or
                           string.find(_name, "heartbeat") or
                           string.find(_name, "integrity") or
                           string.find(_name, "valid") or
                           string.find(_name, "check") or
                           string.find(_name, "security") or
                           string.find(_name, "report") then
                            _AC_Module._blocked_remotes[_child.Name] = true
                        end
                    end
                end)
            end
        end

        _scan_folder(_RS)
        if game:FindFirstChild("ReplicatedFirst") then
            _scan_folder(game.ReplicatedFirst)
        end
    end)
end

-- Ghost position updater (spoof position ke server)
local function _update_ghost_pos()
    pcall(function()
        local _char = _LP.Character or _LP.CharacterAdded:Wait()
        local _hrp = _char:FindFirstChild(_STR._hrp)
        if _hrp then
            _AC_Module._ghost_pos = _hrp.CFrame
        end
    end)
end

-- Initialize all anti-detection
local function _init_anti_detection()
    local _results = {}
    _results.namecall = _setup_namecall_hook()
    _results.index = _setup_index_hook()
    _results.newindex = _setup_newindex_hook()
    _results.connections = _disconnect_ac_connections()
    _scan_ac_remotes()

    -- Periodic ghost position update
    task.spawn(function()
        while _AC_Module._enabled do
            _update_ghost_pos()
            task.wait(1 + math.random() * 2)
        end
    end)

    -- Periodic re-scan for new anti-cheat remotes
    task.spawn(function()
        while _AC_Module._enabled do
            task.wait(30 + math.random() * 30)
            _scan_ac_remotes()
            _disconnect_ac_connections()
        end
    end)

    return _results
end

