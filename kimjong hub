local Util = {}

function Util.wait(min, max)
    min = min or 0.1
    max = max or 0.5
    task.wait(min + math.random() * (max - min))
end

function Util.getChar()
    local s, c = pcall(function()
        return LP.Character or LP.CharacterAdded:Wait()
    end)
    return s and c or nil
end

function Util.getHumanoid()
    local c = Util.getChar()
    return c and c:FindFirstChildOfClass("Humanoid") or nil
end

function Util.getHRP()
    local c = Util.getChar()
    return c and c:FindFirstChild("HumanoidRootPart") or nil
end

function Util.notify(title, text, dur)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "KimJong",
            Text = text or "",
            Duration = dur or 3,
        })
    end)
end

function Util.teleportTo(cf)
    local hrp = Util.getHRP()
    if hrp and typeof(cf) == "CFrame" then
        pcall(function() hrp.CFrame = cf end)
        return true
    end
    return false
end

function Util.findRemote(keyword, parent)
    parent = parent or RS
    local result = nil
    pcall(function()
        for _, obj in ipairs(parent:GetDescendants()) do
            if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then
                if string.find(obj.Name:lower(), keyword:lower()) then
                    result = obj
                    return
                end
            end
        end
    end)
    return result
end

function Util.fireRemote(remote, ...)
    if not remote then return false end
    local s = false
    pcall(function()
        Util.wait(0.05, 0.15)
        if remote:IsA("RemoteEvent") then
            remote:FireServer(...)
            s = true
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer(...)
            s = true
        end
    end)
    return s
end

function Util.firePrompt(prompt)
    if not prompt then return end
    pcall(function()
        if Exec.fireproximityprompt then
            Exec.fireproximityprompt(prompt)
        else
            -- Fallback untuk Delta
            local oldDist = prompt.MaxActivationDistance
            prompt.MaxActivationDistance = 9999
            prompt:InputHoldBegin()
            task.wait(prompt.HoldDuration + 0.1)
            prompt:InputHoldEnd()
            task.wait(0.1)
            prompt.MaxActivationDistance = oldDist
        end
    end)
end

function Util.fireClick(det)
    if not det then return end
    pcall(function()
        if Exec.fireclickdetector then
            Exec.fireclickdetector(det)
        end
    end)
end

