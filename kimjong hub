-- 3A. AUTO CAST MODULE
-- ───────────────────────────────────────────────────────────
function Features.StartAutoCast()
    if State.LoopRunning.AutoCast then return end
    State.LoopRunning.AutoCast = true

    task.spawn(function()
        while State.AutoCast and State.LoopRunning.AutoCast do
            Utilities.SafeCall("AutoCast_Loop", function()
                -- Metode 1: Cari RemoteEvent untuk casting
                local castRemote = Utilities.FindRemote("Cast")
                    or Utilities.FindRemote("cast")
                    or Utilities.FindRemote("CastRod")
                    or Utilities.FindRemote("ThrowRod")
                    or Utilities.FindRemote("UseTool")

                if castRemote then
                    if castRemote:IsA("RemoteEvent") then
                        castRemote:FireServer()
                    elseif castRemote:IsA("RemoteFunction") then
                        castRemote:InvokeServer()
                    end
                else
                    -- Metode 2: Simulasi klik mouse (fallback)
                    -- Aktivasi tool yang sedang di-hold
                    if Character then
                        local tool = Character:FindFirstChildOfClass("Tool")
                        if tool then
                            tool:Activate()
                        end
                    end
                end
            end)
            task.wait(2.5) -- Interval cast (disesuaikan agar realistis)
        end
        State.LoopRunning.AutoCast = false
    end)
end

function Features.StopAutoCast()
    State.LoopRunning.AutoCast = false
end

-- ───────────────────────────────────────────────────────────
-- 3B. AUTO REEL / AUTO CATCH MODULE
-- ───────────────────────────────────────────────────────────
function Features.StartAutoReel()
    if State.LoopRunning.AutoReel then return end
    State.LoopRunning.AutoReel = true

    task.spawn(function()
        while State.AutoReel and State.LoopRunning.AutoReel do
            Utilities.SafeCall("AutoReel_Loop", function()
                -- Strategi 1: Intercept RemoteEvent untuk reel/catch
                local reelRemote = Utilities.FindRemote("Reel")
                    or Utilities.FindRemote("reel")
                    or Utilities.FindRemote("ReelIn")
                    or Utilities.FindRemote("CatchFish")
                    or Utilities.FindRemote("Catch")
                    or Utilities.FindRemote("Pull")

                if reelRemote then
                    if reelRemote:IsA("RemoteEvent") then
                        reelRemote:FireServer()
                    elseif reelRemote:IsA("RemoteFunction") then
                        reelRemote:InvokeServer()
                    end
                end

                -- Strategi 2: Bypass mini-game UI
                -- Cari dan auto-click tombol di mini-game memancing
                if PlayerGui then
                    for _, gui in ipairs(PlayerGui:GetDescendants()) do
                        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                            local nameLower = gui.Name:lower()
                            if (nameLower:find("reel") or nameLower:find("catch")
                                or nameLower:find("pull") or nameLower:find("hook")
                                or nameLower:find("tap") or nameLower:find("click")) then
                                if gui.Visible then
                                    -- Fire semua event click
                                    for _, conn in ipairs(getconnections(gui.MouseButton1Click)) do
                                        conn:Fire()
                                    end
                                    for _, conn in ipairs(getconnections(gui.Activated)) do
                                        conn:Fire()
                                    end
                                end
                            end
                        end
                    end
                end

                -- Strategi 3: Bypass progress bar mini-game
                -- Beberapa game fishing menggunakan value internal
                for _, v in ipairs(PlayerGui:GetDescendants()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        local nameLower = v.Name:lower()
                        if nameLower:find("progress") or nameLower:find("reel")
                           or nameLower:find("tension") then
                            v.Value = v.Value + 100 -- Force max progress
                        end
                    end
                end
            end)
            task.wait(0.15) -- Cek cepat untuk responsif
        end
        State.LoopRunning.AutoReel = false
    end)
end

function Features.StopAutoReel()
    State.LoopRunning.AutoReel = false
end

