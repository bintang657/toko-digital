_Features.fpsBoost = function(enabled)
    _States.fps_boost = enabled
    if enabled then
        _Util.notify("FPS Boost", "ENABLED - Removing unnecessary effects", 3)
        pcall(function()
            -- Reduce rendering quality
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

            -- Remove particles, beams, trails
            for _, _obj in ipairs(_WS:GetDescendants()) do
                pcall(function()
                    if _obj:IsA("ParticleEmitter") or _obj:IsA("Trail") or
                       _obj:IsA("Beam") or _obj:IsA("Fire") or
                       _obj:IsA("Smoke") or _obj:IsA("Sparkles") or
                       _obj:IsA("PointLight") or _obj:IsA("SpotLight") or
                       _obj:IsA("SurfaceLight") then
                        _obj.Enabled = false
                    end

                    -- Reduce texture quality
                    if _obj:IsA("Decal") or _obj:IsA("Texture") then
                        _obj.Transparency = 1
                    end

                    -- Remove grass/foliage
                    if _obj:IsA("BasePart") then
                        local _n = _obj.Name:lower()
                        if string.find(_n, "grass") or string.find(_n, "leaf") or
                           string.find(_n, "flower") or string.find(_n, "bush") or
                           string.find(_n, "tree") or string.find(_n, "decor") then
                            if not _obj:FindFirstChildOfClass("ClickDetector") and
                               not _obj:FindFirstChildOfClass("ProximityPrompt") then
                                _obj.Transparency = 1
                                _obj.CanCollide = false
                            end
                        end
                        _obj.Material = Enum.Material.SmoothPlastic
                        _obj.Reflectance = 0
                    end

                    if _obj:IsA("MeshPart") then
                        _obj.TextureID = ""
                    end
                end)
            end

            -- Remove post-processing
            for _, _e in ipairs(_Lighting:GetChildren()) do
                if _e:IsA("PostEffect") or _e:IsA("BloomEffect") or
                   _e:IsA("BlurEffect") or _e:IsA("ColorCorrectionEffect") or
                   _e:IsA("DepthOfFieldEffect") or _e:IsA("SunRaysEffect") then
                    _e.Enabled = false
                end
                if _e:IsA("Atmosphere") then
                    _e.Density = 0
                end
            end

            -- Disable terrain details
            if _WS.Terrain then
                _WS.Terrain.WaterWaveSize = 0
                _WS.Terrain.WaterWaveSpeed = 0
                _WS.Terrain.Decoration = false
            end
        end)
    else
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        end)
        _Util.notify("FPS Boost", "DISABLED (some changes require rejoin)", 3)
    end
end

