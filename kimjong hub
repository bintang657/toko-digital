-- Obfuscated strings (example)
local function obf(str) -- not used heavily, but kept
    local bytes = {}
    for i = 1, #str do
        bytes[i] = string.byte(str, i)
    end
    return table.concat(bytes, ",")
end

local function deobf(str)
    local bytes = {}
    for v in string.gmatch(str, "[^,]+") do
        table.insert(bytes, tonumber(v))
    end
    return string.char(unpack(bytes))
end

