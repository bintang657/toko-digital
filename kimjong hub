local Utility = {}

-- Find a remote event/function by pattern
function Utility.findRemote(pattern)
    local remotes = {}
    local function search(obj)
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            if not pattern or obj.Name:lower():find(pattern) then
                table.insert(remotes, obj)
            end
        end
        for _, child in ipairs(obj:GetChildren()) do
            search(child)
        end
    end
    search(game:GetService("ReplicatedStorage"))
    search(Player.PlayerScripts)
    search(Player.Backpack)
    return remotes
end

-- Random wait
function Utility.delayedWait(min, max)
    local delay = math.random() * (max - min) + min
    task.wait(delay)
end

-- Safely get character parts
function Utility.getChar()
    return Player.Character or Player.CharacterAdded:Wait()
end

-- Teleport function
function Utility.teleport(cframe)
    local char = Utility.getChar()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = cframe
    end
end

-- Get fishing spots from workspace (heuristic)
function Utility.getFishingSpots()
    local spots = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Part") and (v.Name:lower():find("fish") or v.Name:lower():find("spot") or v.Name:lower():find("water")) then
            table.insert(spots, v)
        end
    end
    return spots
end

-- Find all fish models
function Utility.getFish()
    local fish = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Name:lower():find("fish") then
            table.insert(fish, v)
        end
    end
    return fish
end

