-- Auto Fish
_Features.autoFish = function(enabled)
    _States.auto_fish = enabled
    if enabled then
        task.spawn(function()
            _Util.notify("Auto Fish", "Auto Fish ENABLED", 2)
            while _States.auto_fish do
                pcall(function()
                    -- Step 1: Cast rod
                    local _cast_remote = _GameData.remotes.cast
                    if _cast_remote then
                        _Util.fireRemote(_cast_remote)
                        _rnd_delay(0.5, 1.5) -- Wait for cast

                        -- Step 2: Wait for bite (simulated)
                        _rnd_delay(1.0, 3.0)

                        -- Step 3: Reel/Catch
                        local _catch_remote = _GameData.remotes.catch or _GameData.remotes.reel
                        if _catch_remote then
                            if _States.auto_perfect then
                                -- Send perfect timing argument
                                _Util.fireRemote(_catch_remote, "Perfect", 1, true)
                            else
                                _Util.fireRemote(_catch_remote, "Good", 0.8)
                            end
