-- SECTION 7: LIVE CLOCK ON WATERMARK (BONUS)
-- ═══════════════════════════════════════════════════════════

task.spawn(function()
    while getgenv().KimJongLoaded do
        Utilities.SafeCall("WatermarkClock", function()
            local watermarkGui = CoreGui:FindFirstChild("KimJongWatermark")
                or (PlayerGui and PlayerGui:FindFirstChild("KimJongWatermark"))
            if watermarkGui then
                local label = watermarkGui:FindFirstChild("WatermarkFrame")
                    and watermarkGui.WatermarkFrame:FindFirstChild("WatermarkLabel")
                if label then
                    local timeStr = os.date("%H:%M:%S")
                    local fps = math.floor(1 / RunService.RenderStepped:Wait())
                    label.Text = string.format(
                        "🎣 kimjong sc | v1.0 | ⏰ %s | 📊 %d FPS",
                        timeStr, fps
                    )
                end
            end
        end)
        task.wait(0.5)
    end
end)
