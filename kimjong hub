local flyBody, flyGyro = nil, nil

function Features.flyHack(enabled)
    States.flyHack = enabled

    if not enabled then
        pcall(function()
            if flyBody then flyBody:Destroy(); flyBody = nil end
            if flyGyro then flyGyro:Destroy(); flyGyro = nil end
        end)
        removeConn("fly")
        Util.notify("Fly", "DISABLED", 2)
        return
    end

    Util.notify("Fly", "ENABLED (E=Up, Q=Down)", 3)
    task.spawn(function()
        local hrp = Util.getHRP()
        if not hrp then return end

        pcall(function()
            if flyBody then flyBody:Destroy() end
            if flyGyro then flyGyro:Destroy() end
        end)

        flyBody = Instance.new("BodyVelocity")
        flyBody.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        flyBody.Velocity = Vector3.new(0, 0, 0)
        flyBody.Parent = hrp

        flyGyro = Instance.new("BodyGyro")
        flyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        flyGyro.P = 9e4
        flyGyro.Parent = hrp

        local flySpeed = States.speedValue or 50
        local camera = Workspace.CurrentCamera

        local conn = RunService.RenderStepped:Connect(function()
            if not States.flyHack then
                pcall(function()
                    if flyBody then flyBody:Destroy(); flyBody = nil end
                    if flyGyro then flyGyro:Destroy(); flyGyro = nil end
                end)
                return
            end

            pcall(function()
                if not flyBody or not flyGyro or not hrp or not hrp.Parent then return end

                flyGyro.CFrame = camera.CFrame
                local vel = Vector3.new(0, 0, 0)
                local cf = camera.CFrame

                if UIS:IsKeyDown(Enum.KeyCode.W) then vel = vel + cf.LookVector * flySpeed end
                if UIS:IsKeyDown(Enum.KeyCode.S) then vel = vel - cf.LookVector * flySpeed end
                if UIS:IsKeyDown(Enum.KeyCode.A) then vel = vel - cf.RightVector * flySpeed end
                if UIS:IsKeyDown(Enum.KeyCode.D) then vel = vel + cf.RightVector * flySpeed end
                if UIS:IsKeyDown(Enum.KeyCode.E) then vel = vel + Vector3.new(0, flySpeed, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.Q) then vel = vel - Vector3.new(0, flySpeed, 0) end

                flyBody.Velocity = vel
            end)
        end)

        addConn("fly", conn)
    end)
end

