-- 3D. EQUIP ROD MODULE
-- ───────────────────────────────────────────────────────────
function Features.EquipRod(rodName)
    Utilities.SafeCall("EquipRod", function()
        if not rodName or rodName == "" then return end

        -- Cek di Backpack
        local tool = Backpack:FindFirstChild(rodName)
        if tool and tool:IsA("Tool") then
            Humanoid:EquipTool(tool)
            State.EquippedRod = rodName
            return
        end

        -- Cek apakah sudah di Character (sudah di-equip)
        if Character then
            local equipped = Character:FindFirstChild(rodName)
            if equipped and equipped:IsA("Tool") then
                State.EquippedRod = rodName
                return
            end
        end

        warn("[kimjong sc] Rod tidak ditemukan: " .. rodName)
    end)
end

