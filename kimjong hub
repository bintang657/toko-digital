-- Custom Watermark di atas layar
Utilities.SafeCall("CreateWatermark", function()
    -- Cek apakah sudah ada watermark
    if CoreGui:FindFirstChild("KimJongWatermark") then
        CoreGui:FindFirstChild("KimJongWatermark"):Destroy()
    end

    local watermarkGui = Instance.new("ScreenGui")
    watermarkGui.Name = "KimJongWatermark"
    watermarkGui.ResetOnSpawn = false
    watermarkGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    watermarkGui.IgnoreGuiInset = true
    watermarkGui.DisplayOrder = 999

    -- Coba parent ke CoreGui, fallback ke PlayerGui
    local success = pcall(function()
        watermarkGui.Parent = CoreGui
    end)
    if not success then
        watermarkGui.Parent = PlayerGui
    end

    -- Watermark background frame
    local watermarkFrame = Instance.new("Frame")
    watermarkFrame.Name = "WatermarkFrame"
    watermarkFrame.Size = UDim2.new(0, 280, 0, 32)
    watermarkFrame.Position = UDim2.new(0.5, -140, 0, 8)
    watermarkFrame.AnchorPoint = Vector2.new(0, 0)
    watermarkFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    watermarkFrame.BackgroundTransparency = 0.15
    watermarkFrame.BorderSizePixel = 0
    watermarkFrame.Parent = watermarkGui

    -- Rounded corners
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = watermarkFrame

    -- Subtle border/stroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 80, 200) -- Purple accent
    stroke.Thickness = 1.5
    stroke.Transparency = 0.3
    stroke.Parent = watermarkFrame

    -- Gradient on stroke for elegance
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 80, 220)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(60, 180, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 80, 220)),
    })
    gradient.Parent = stroke

    -- Watermark text
    local watermarkText = Instance.new("TextLabel")
    watermarkText.Name = "WatermarkLabel"
    watermarkText.Size = UDim2.new(1, -16, 1, 0)
    watermarkText.Position = UDim2.new(0, 8, 0, 0)
    watermarkText.BackgroundTransparency = 1
    watermarkText.Text = "🎣 kimjong sc | v1.0"
    watermarkText.TextColor3 = Color3.fromRGB(220, 220, 240)
    watermarkText.Font = Enum.Font.GothamBold
    watermarkText.TextSize = 14
    watermarkText.TextXAlignment = Enum.TextXAlignment.Center
    watermarkText.Parent = watermarkFrame

    -- Animate gradient rotation for a subtle shimmer effect
    task.spawn(function()
        local rotation = 0
        while watermarkGui and watermarkGui.Parent do
            rotation = (rotation + 1) % 360
            gradient.Rotation = rotation
            task.wait(0.03)
        end
    end)
    -- Fade-in animation
    watermarkFrame.BackgroundTransparency = 1
    watermarkText.TextTransparency = 1

    local fadeInBg = TweenService:Create(watermarkFrame, TweenInfo.new(1, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0.15
    })
    local fadeInText = TweenService:Create(watermarkText, TweenInfo.new(1, Enum.EasingStyle.Quad), {
        TextTransparency = 0
    })

    fadeInBg:Play()
    fadeInText:Play()

    -- Tambahkan ke State untuk cleanup
    table.insert(State.Connections, {
        Disconnect = function()
            if watermarkGui and watermarkGui.Parent then
                watermarkGui:Destroy()
            end
        end,
        Connected = true
    })
end)
