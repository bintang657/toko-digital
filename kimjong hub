local GameData = {
    remotes = {},
    locations = {
        fishingSpots = {},
        shop = nil,
        sellArea = nil,
        eventArea = nil,
        secretSpots = {},
        spawn = nil,
    },
    npcs = {},
    treasures = {},
    analyzed = false,
}

function GameData.analyze()
    print("[KimJong] Analyzing game...")

    -- Scan remotes
    pcall(function()
        local searchFolders = {RS}

        -- Common remote folder names
        local folderNames = {"Remotes", "Events", "Network", "Remote",
                            "Shared", "Communication", "Modules", "Signals"}
        for _, name in ipairs(folderNames) do
            local f = RS:FindFirstChild(name)
            if f then table.insert(searchFolders, f) end
        end

        local remoteMap = {
            cast = {"cast", "throw", "rod", "fish", "start", "begin", "launch"},
            catch = {"catch", "grab", "hook", "complete", "finish", "success"},
            reel = {"reel", "pull", "drag", "wind"},
            sell = {"sell", "vendor"},
            buy = {"buy", "purchase", "shop"},
            equip = {"equip", "wear", "select", "use"},
            collect = {"collect", "claim", "reward", "pickup", "loot"},
            quest = {"quest", "mission", "task", "objective"},
            bait = {"bait", "lure"},
            upgrade = {"upgrade", "enhance", "improve", "level"},
        }

        for _, folder in ipairs(searchFolders) do
            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA(STR.RemoteEvent) or obj:IsA(STR.RemoteFunction) then
                    local n = obj.Name:lower()
                    -- Skip anti-cheat remotes
                    if not AntiCheat.blockedRemotes[obj.Name] then
                        for category, keywords in pairs(remoteMap) do
                            if not GameData.remotes[category] then
                                for _, kw in ipairs(keywords) do
                                    if string.find(n, kw) then
                                        GameData.remotes[category] = obj
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)

    -- Scan workspace for locations
    pcall(function()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            local n = obj.Name:lower()

            -- Fishing spots
            if (string.find(n, "fish") and (string.find(n, "spot") or string.find(n, "zone") or string.find(n, "area")))
               or string.find(n, "castzone") or string.find(n, "fishingspot") then
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    table.insert(GameData.locations.fishingSpots, obj)
                end
            end

            -- Shop
            if not GameData.locations.shop then
                if string.find(n, "shop") or string.find(n, "store") then
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        GameData.locations.shop = obj
                    end
                end
            end

            -- Sell area
            if not GameData.locations.sellArea then
                if string.find(n, "sell") then
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        GameData.locations.sellArea = obj
                    end
                end
            end

            -- Event area
            if not GameData.locations.eventArea then
                if string.find(n, "event") then
                    if obj:IsA("Model") or obj:IsA("BasePart") then
                        GameData.locations.eventArea = obj
                    end
                end
            end

            -- Secret spots
            if string.find(n, "secret") or string.find(n, "hidden") then
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    table.insert(GameData.locations.secretSpots, obj)
                end
            end

            -- NPCs (models with humanoid that arent players)
            if obj:IsA("Model") and obj:FindFirstChildOfClass(STR.Humanoid) then
                local isPlayer = false
                pcall(function()
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.Character == obj then isPlayer = true end
                    end
                end)
                if not isPlayer and obj ~= LP.Character then
                    table.insert(GameData.npcs, obj)
                end
            end

            -- Treasures
            if string.find(n, "chest") or string.find(n, "treasure") or string.find(n, "crate") then
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    table.insert(GameData.treasures, obj)
                end
            end
        end

        -- Spawn
        pcall(function()
            local sp = Workspace:FindFirstChild("SpawnLocation") or Workspace:FindFirstChild("Spawn")
            if sp then GameData.locations.spawn = sp end
        end)
    end)

    GameData.analyzed = true

    -- Print results
    local remoteCount = 0
    for _, v in pairs(GameData.remotes) do
        if v then remoteCount = remoteCount + 1 end
    end

    print("[KimJong] Analysis complete:")
    print("  Remotes: " .. remoteCount)
    print("  Fishing spots: " .. #GameData.locations.fishingSpots)
    print("  NPCs: " .. #GameData.npcs)
    print("  Treasures: " .. #GameData.treasures)

    -- Print found remotes
    for name, remote in pairs(GameData.remotes) do
        if remote then
            print("  Remote [" .. name .. "]: " .. remote:GetFullName())
        end
    end
end

