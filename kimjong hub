        if Character and HumanoidRootPart then
            -- Matikan physics sesaat untuk teleport yang mulus
            HumanoidRootPart.CFrame = targetCFrame
        end
    end)
end

--- Cari remote event/function di ReplicatedStorage secara rekursif
---@param name string Nama remote yang dicari
---@param parent Instance Parent tempat mencari (default: ReplicatedStorage)
---@return Instance|nil
function Utilities.FindRemote(name, parent)
    parent = parent or ReplicatedStorage
    local remote = nil
    Utilities.SafeCall("FindRemote", function()
        -- Cari langsung
        remote = parent:FindFirstChild(name, true)
        if not remote then
            -- Fallback: cari di seluruh descendants
            for _, v in ipairs(parent:GetDescendants()) do
                if v.Name == name and (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) then
                    remote = v
                    break
                end
            end
        end
    end)
    return remote
end

--- Buat ESP BillboardGui pada suatu instance
---@param target Instance Object target untuk ESP
---@param text string Teks yang ditampilkan
---@param color Color3 Warna teks
---@param category string Kategori ESP (untuk tracking cleanup)
---@return BillboardGui|nil
function Utilities.CreateESP(target, text, color, category)
    local billboard = nil
    Utilities.SafeCall("CreateESP", function()
        -- Cek duplikat
        if target:FindFirstChild("KimJongESP") then
            target:FindFirstChild("KimJongESP"):Destroy()
        end

        billboard = Instance.new("BillboardGui")
        billboard.Name = "KimJongESP"
        billboard.Adornee = target
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = target

        local textLabel = Instance.new("TextLabel")
        textLabel.Name = "ESPLabel"
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = color
        textLabel.TextStrokeTransparency = 0.3
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 14
        textLabel.TextScaled = false
        textLabel.Text = text
        textLabel.Parent = billboard

        -- Track untuk cleanup nanti
        table.insert(State.ESPObjects, {
            Billboard = billboard,
            Target = target,
            Label = textLabel,
            Category = category
        })
    end)
    return billboard
end

--- Hapus semua ESP berdasarkan kategori
---@param category string Kategori ESP yang mau dihapus
function Utilities.ClearESP(category)
    Utilities.SafeCall("ClearESP", function()
        local remaining = {}
        for _, espData in ipairs(State.ESPObjects) do
            if espData.Category == category then
                if espData.Billboard and espData.Billboard.Parent then
                    espData.Billboard:Destroy()
                end
            else
                table.insert(remaining, espData)
            end
        end
        State.ESPObjects = remaining
    end)
end

--- Mendapatkan jarak antara player dan posisi tertentu
---@param position Vector3
---@return number
function Utilities.GetDistance(position)
    if HumanoidRootPart then
        return (HumanoidRootPart.Position - position).Magnitude
    end
    return math.huge
end

--- Mencari semua rod di inventory player
---@return table<string>
function Utilities.GetRodsInInventory()
    local rods = {}
    Utilities.SafeCall("GetRodsInInventory", function()
        -- Cek Backpack
        for _, item in ipairs(Backpack:GetChildren()) do
            if item:IsA("Tool") then
                local nameLower = item.Name:lower()
                if nameLower:find("rod") or nameLower:find("pole")
                   or nameLower:find("joran") or nameLower:find("fishing") then
                    table.insert(rods, item.Name)
                end
            end
        end
        -- Cek yang sedang di-equip di Character
        if Character then
            for _, item in ipairs(Character:GetChildren()) do
                if item:IsA("Tool") then
                    local nameLower = item.Name:lower()
                    if nameLower:find("rod") or nameLower:find("pole")
                       or nameLower:find("joran") or nameLower:find("fishing") then
                        -- Hindari duplikat
                        local found = false
                        for _, r in ipairs(rods) do
                            if r == item.Name then found = true; break end
                        end
                        if not found then
                            table.insert(rods, item.Name)
                        end
                    end
                end
            end
        end
        -- Fallback: jika tidak ada yang cocok, tambahkan semua Tool
        if #rods == 0 then
            for _, item in ipairs(Backpack:GetChildren()) do
                if item:IsA("Tool") then
                    table.insert(rods, item.Name)
                end
            end
        end
    end)
    return rods
end

