        flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        flyBV.Velocity = Vector3.new(0, 0, 0)
        flyBV.Parent = hrp

        flyBG = Instance.new("BodyGyro")
        flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        flyBG.P = 9e4
        flyBG.Parent = hrp

        local spd = S.speedVal or 50
        local cam = WS.CurrentCamera

        local conn = RunService.RenderStepped:Connect(function()
            if not S.fly then return end
            pcall(function()
                if not flyBV or not flyBG or not hrp or not hrp.Parent then return end
                flyBG.CFrame = cam.CFrame

                local v = Vector3.new(0, 0, 0)
                if UIS:IsKeyDown(Enum.KeyCode.W) then v = v + cam.CFrame.LookVector * spd end
                if UIS:IsKeyDown(Enum.KeyCode.S) then v = v - cam.CFrame.LookVector * spd end
                if UIS:IsKeyDown(Enum.KeyCode.A) then v = v - cam.CFrame.RightVector * spd end
                if UIS:IsKeyDown(Enum.KeyCode.D) then v = v + cam.CFrame.RightVector * spd end
                if UIS:IsKeyDown(Enum.KeyCode.E) then v = v + Vector3.new(0, spd, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.Q) then v = v - Vector3.new(0, spd, 0) end

                flyBV.Velocity = v
            end)
        end)
        addC("fly", conn)
    end)
end

