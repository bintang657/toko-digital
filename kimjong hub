local function cleanup()
    Util.notify("KimJong", "Unloading script...", 3)

    -- Disable all states
    for k, v in pairs(States) do
        if type(v) == "boolean" then States[k] = false end
    end

    task.wait(0.5)

    -- Disconnect all connections
    for name, conn in pairs(Connections) do
        pcall(function() conn:Disconnect() end)
    end
    Connections = {}

    -- Clear all ESP
    for cat, _ in pairs(ESPData) do
        clearESP(cat)
    end

    -- Remove fly parts
    pcall(function()
        if flyBody then flyBody:Destroy(); flyBody = nil end
        if flyGyro then flyGyro:Destroy(); flyGyro = nil end
    end)

    -- Reset player
    pcall(function()
        local hum = Util.getHumanoid()
        if hum then hum.WalkSpeed = 16; hum.JumpPower = 50 end
    end)

    pcall(function() Workspace.CurrentCamera.FieldOfView = 70 end)

    -- Remove GUI
    pcall(function()
        for _, g in ipairs(game:GetService("CoreGui"):GetChildren()) do
            if g:IsA("ScreenGui") and string.find(g.Name, "_kj_") then
                g:Destroy()
            end
        end
    end)

    AntiCheat.enabled = false
    warn("[KimJong] Unloaded.")
end

