-- [[ UTILITY FUNCTIONS ]]
local Utility = {}

-- Fungsi untuk mencari remote event berdasarkan pola nama
function Utility:FindRemote(pattern)
    for _, remote in pairs(game:GetDescendants()) do
        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
            if remote.Name:lower():find(pattern:lower()) then
                return remote
            end
        end
    end
    return nil
end

-- Fungsi untuk mendapatkan karakter player
function Utility:GetCharacter()
    return game.Players.LocalPlayer.Character or game.Players.LocalPlayer.CharacterAdded:Wait()
end

-- Fungsi untuk mendapatkan Humanoid
function Utility:GetHumanoid()
    local char = self:GetCharacter()
    return char and char:FindFirstChild("Humanoid")
end

-- Fungsi untuk mendapatkan rod saat ini
function Utility:GetCurrentRod()
    -- Implementasi tergantung game, biasanya di PlayerGui atau Backpack
    local backpack = game.Players.LocalPlayer.Backpack
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") and item.Name:lower():find("rod") then
            return item
        end
    end
    return nil
end

-- Fungsi untuk mendapatkan semua fishing spots
function Utility:GetFishingSpots()
    local spots = {}
    -- Cari part dengan nama "FishingSpot" atau "WaterZone"
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Part") and (obj.Name:lower():find("fishing") or obj.Name:lower():find("spot") or obj.Name:lower():find("water")) then
            table.insert(spots, obj)
        end
    end
    return spots
end

-- Fungsi untuk teleport ke posisi
function Utility:TeleportTo(position)
    local char = self:GetCharacter()
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = position
    end
end

-- Fungsi untuk notifikasi
