        _createToggleBtn("Auto Upgrade", _o, function(v) _Features.autoUpgrade(v) end); _o = _o + 1

        _createSectionLabel("🔧 UTILITY", _o); _o = _o + 1
        _createToggleBtn("Anti-AFK", _o, function(v) _Features.antiAFK(v) end); _o = _o + 1
        _createToggleBtn("FPS Booster", _o, function(v) _Features.fpsBoost(v) end); _o = _o + 1
        _createActionBtn("Server Hop", _o, function() _Features.serverHop() end); _o = _o + 1
        _createActionBtn("Rejoin Server", _o, function() _Features.rejoin() end); _o = _o + 1
        _createToggleBtn("Chat Spam", _o, function(v) _Features.chatSpam(v) end); _o = _o + 1

        _createSectionLabel("⚙️ SETTINGS", _o); _o = _o + 1
        _createToggleBtn("Anti-Cheat Bypass", _o, function(v)
            _AC_Module._enabled = v
        end); _o = _o + 1
        _createActionBtn("Re-Analyze Game", _o, function()
            _analyze_game()
            _Util.notify("Analysis", "Game re-analyzed!", 3)
        end); _o = _o + 1
        _createActionBtn("Destroy Script", _o, function()
            _cleanup()
        end); _o = _o + 1

        -- Close button logic
        _close.MouseButton1Click:Connect(function()
            _sg:Destroy()
        end)

        -- Minimize logic
        local _minimized = false
        _minimize.MouseButton1Click:Connect(function()
            _minimized = not _minimized
            _scroll.Visible = not _minimized
            if _minimized then
                _main.Size = UDim2.new(0, 500, 0, 45)
                _minimize.Text = "+"
            else
                _main.Size = UDim2.new(0, 500, 0, 400)
                _minimize.Text = "-"
            end
        end)

        -- Toggle UI with RightShift
        _UIS.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.KeyCode == Enum.KeyCode.RightShift then
                _sg.Enabled = not _sg.Enabled
            end
        end)

        _UI_Loaded = true
        return true
    end
end

-- ============================================================
-- SECTION 6: CLEANUP FUNCTION
-- ============================================================

function _cleanup()
    _Util.notify("Script KimJong", "Cleaning up and unloading...", 3)

    -- Disable all features
    for _key, _val in pairs(_States) do
        if type(_val) == "boolean" then
            _States[_key] = false
        end
    end

    -- Wait for features to stop
    task.wait(0.5)

    -- Disconnect all connections
    for _name, _conn in pairs(_Connections) do
        pcall(function() _conn:Disconnect() end)
    end
    _Connections = {}

    -- Clear ESP
    for _cat, _ in pairs(_esp_objects) do
        _clearESP(_cat)
    end

    -- Remove fly parts
    pcall(function()
        if _flyBody then _flyBody:Destroy() end
        if _flyGyro then _flyGyro:Destroy() end
    end)

    -- Reset player
    pcall(function()
        local _hum = _Util.getHumanoid()
        if _hum then
            _hum.WalkSpeed = 16
            _hum.JumpPower = 50
        end
    end)

    -- Reset camera
    pcall(function()
        _WS.CurrentCamera.FieldOfView = 70
    end)

    -- Disable anti-cheat module
    _AC_Module._enabled = false

    -- Destroy UI
    pcall(function()
        if _UI_Lib and _UI_Lib.Destroy then
            _UI_Lib:Destroy()
        end
    end)

    -- Destroy fallback GUI
    pcall(function()
        local _cg = game:GetService("CoreGui")
        for _, _g in ipairs(_cg:GetChildren()) do
            if _g:IsA("ScreenGui") and string.find(_g.Name, "_kj_") then
                _g:Destroy()
            end
        end
    end)

    warn("[Script KimJong] Unloaded successfully.")
end

