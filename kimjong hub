-- 3C. AUTO SELL MODULE
-- ───────────────────────────────────────────────────────────
function Features.StartAutoSell()
    if State.LoopRunning.AutoSell then return end
    State.LoopRunning.AutoSell = true

    task.spawn(function()
        while State.AutoSell and State.LoopRunning.AutoSell do
            Utilities.SafeCall("AutoSell_Loop", function()
