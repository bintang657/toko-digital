local function _main()
    print("╔══════════════════════════════════════╗")
    print("║    Script KimJong v2.0 - Fish It     ║")
    print("║    Loading...                         ║")
    print("╚══════════════════════════════════════╝")

    -- Step 1: Initialize Anti-Detection
    print("[1/4] Initializing anti-detection...")
    local _ac_results = _init_anti_detection()
    print("  Namecall hook: " .. tostring(_ac_results.namecall))
    print("  Index hook: " .. tostring(_ac_results.index))
    print("  Newindex hook: " .. tostring(_ac_results.newindex))
