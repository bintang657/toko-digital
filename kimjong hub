-- Connection manager
local function _addConnection(name, conn)
    if _Connections[name] then
        pcall(function() _Connections[name]:Disconnect() end)
    end
    _Connections[name] = conn
end

local function _removeConnection(name)
    if _Connections[name] then
        pcall(function() _Connections[name]:Disconnect() end)
        _Connections[name] = nil
    end
end

