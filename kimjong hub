local ESPData = {fish = {}, player = {}, item = {}, npc = {}, treasure = {}}

local function createESP(obj, color, text, category)
    local ok = pcall(function()
        local bb = Instance.new("BillboardGui")
        bb.Name = "_kj_esp"
        bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.StudsOffset = Vector3.new(0, 3, 0)

        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 0.5
        tl.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.Text = text
        tl.TextColor3 = color
        tl.TextScaled = true
        tl.Font = Enum.Font.GothamBold
        tl.Parent = bb

        local tc = Instance.new("UICorner")
        tc.CornerRadius = UDim.new(0, 4)
        tc.Parent = tl

        local target = obj
        if obj:IsA("Model") then
            target = obj.PrimaryPart or obj:FindFirstChild(STR.HumanoidRootPart) or obj:FindFirstChildWhichIsA("BasePart")
        end

        if target and target:IsA("BasePart") then
            bb.Adornee = target
            bb.Parent = target

            local hl = Instance.new("Highlight")
            hl.Name = "_kj_hl"
            hl.FillColor = color
            hl.FillTransparency = 0.7
            hl.OutlineColor = color
            hl.OutlineTransparency = 0.3
            hl.Parent = obj

            table.insert(ESPData[category], {bb = bb, hl = hl, obj = obj})
        else
            bb:Destroy()
        end
    end)
end

local function clearESP(category)
    if ESPData[category] then
        for _, data in ipairs(ESPData[category]) do
            pcall(function() data.bb:Destroy() end)
            pcall(function() data.hl:Destroy() end)
        end
        ESPData[category] = {}
    end
end

