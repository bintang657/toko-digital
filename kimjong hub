local Util = {}

-- Random delay (anti-pattern detection)
function Util.randomDelay(min, max)
    min = min or 0.1
    max = max or 0.5
    local d = min + math.random() * (max - min)
    task.wait(d)
    return d
end

-- Safe get character
function Util.getChar()
    local ok, char = pcall(function()
        return LP.Character or LP.CharacterAdded:Wait()
    end)
    return ok and char or nil
end

-- Safe get humanoid
function Util.getHumanoid()
    local char = Util.getChar()
    if char then
        return char:FindFirstChildOfClass(STR.Humanoid)
    end
    return nil
end

-- Safe get HumanoidRootPart
function Util.getHRP()
    local char = Util.getChar()
    if char then
        return char:FindFirstChild(STR.HumanoidRootPart)
    end
    return nil
end

-- Notification (safe)
function Util.notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "KimJong",
            Text = text or "",
            Duration = duration or 3,
        })
    end)
end

-- Find remote by partial name
function Util.findRemote(partialName, parent)
    parent = parent or RS
    local result = nil
    pcall(function()
        -- Exact match first
        local exact = parent:FindFirstChild(partialName, true)
        if exact and (exact:IsA(STR.RemoteEvent) or exact:IsA(STR.RemoteFunction)) then
            result = exact
            return
        end
        -- Partial match
        for _, d in ipairs(parent:GetDescendants()) do
            if (d:IsA(STR.RemoteEvent) or d:IsA(STR.RemoteFunction)) then
                if string.find(d.Name:lower(), partialName:lower()) then
                    result = d
                    return
                end
            end
        end
    end)
    return result
end

-- Safe fire remote
function Util.fireRemote(remote, ...)
    if not remote then return false end
    local ok, err = pcall(function()
        Util.randomDelay(0.05, 0.15)
        if remote:IsA(STR.RemoteEvent) then
            remote:FireServer(...)
        elseif remote:IsA(STR.RemoteFunction) then
            return remote:InvokeServer(...)
        end
    end)
    return ok
end

-- Safe teleport
function Util.teleportTo(cf)
    local hrp = Util.getHRP()
    if not hrp then return false end
    local ok = pcall(function()
        hrp.CFrame = cf
    end)
    return ok
end

-- Fire proximity prompt (safe)
function Util.firePrompt(prompt)
    if not prompt then return end
    pcall(function()
        if _ENV.fireproximityprompt then
            _ENV.fireproximityprompt(prompt)
        else
            -- Fallback: simulate proximity prompt
            prompt.MaxActivationDistance = 9999
            prompt:InputHoldBegin()
            task.wait(prompt.HoldDuration + 0.1)
            prompt:InputHoldEnd()
            prompt.MaxActivationDistance = prompt.MaxActivationDistance
        end
    end)
end

-- Fire click detector (safe)
function Util.fireClick(detector)
    if not detector then return end
    pcall(function()
        if _ENV.fireclickdetector then
            _ENV.fireclickdetector(detector)
        else
            -- Fallback
            detector.MaxActivationDistance = 9999
            detector:_fireclickdetector(LP, "MouseClick")
        end
    end)
end

