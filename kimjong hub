local Features = {}

-- ====== A. FISHING ======

function Features.autoFish(enabled)
    States.autoFish = enabled
    if not enabled then
        Util.notify("Auto Fish", "DISABLED", 2)
        return
    end

    Util.notify("Auto Fish", "ENABLED", 2)
    task.spawn(function()
        while States.autoFish do
            pcall(function()
                local castRemote = GameData.remotes.cast
                local catchRemote = GameData.remotes.catch or GameData.remotes.reel

                if castRemote then
                    -- Cast
                    Util.fireRemote(castRemote)
                    Util.randomDelay(0.8, 2.0)

                    -- Wait for bite
                    Util.randomDelay(1.0, 3.0)

                    -- Catch
                    if catchRemote then
                        if States.autoPerfect then
                            Util.fireRemote(catchRemote, "Perfect", 1, true)
                        else
                            Util.fireRemote(catchRemote, "Good", 0.8)
                        end
                        Util.randomDelay(0.3, 0.8)
                    end
                else
                    -- Fallback: Interact with fishing spots via proximity/click
                    local hrp = Util.getHRP()
                    if hrp then
                        for _, spot in ipairs(GameData.locations.fishingSpots) do
                            pcall(function()
                                local pos
                                if spot:IsA("Model") then
                                    pos = spot:GetBoundingBox().Position
                                elseif spot:IsA("BasePart") then
                                    pos = spot.Position
                                end

                                if pos and (hrp.Position - pos).Magnitude < 50 then
                                    -- Try ProximityPrompt
                                    for _, d in ipairs(spot:GetDescendants()) do
                                        if d:IsA("ProximityPrompt") then
                                            Util.firePrompt(d)
                                        elseif d:IsA("ClickDetector") then
                                            Util.fireClick(d)
                                        end
                                    end
                                end
                            end)
                        end
                    end
                    Util.randomDelay(1.5, 3.0)
                end
            end)
            Util.randomDelay(0.3, 0.8)
        end
    end)
end

