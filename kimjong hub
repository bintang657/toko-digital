local function addSection(pageIdx, text)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -6, 0, 18)
    lbl.BackgroundTransparency = 1
    lbl.Text = "── " .. text .. " ──"
    lbl.TextColor3 = Color3.fromRGB(0, 180, 255)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 11
    lbl.LayoutOrder = ordIdx[pageIdx]
    lbl.Parent = pages[pageIdx]
    ordIdx[pageIdx] = ordIdx[pageIdx] + 1
end

local function addToggle(pageIdx, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -6, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(32, 32, 48)
    btn.Text = " ❌ " .. text
    btn.TextColor3 = Color3.fromRGB(185, 185, 185)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.LayoutOrder = ordIdx[pageIdx]
    btn.Parent = pages[pageIdx]
    pcall(function() Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5) end)

    local on = false
    btn.MouseButton1Click:Connect(function()
        on = not on
        btn.Text = on and (" ✅ " .. text) or (" ❌ " .. text)
        btn.BackgroundColor3 = on and Color3.fromRGB(0, 65, 30) or Color3.fromRGB(32, 32, 48)
        pcall(callback, on)
    end)
    ordIdx[pageIdx] = ordIdx[pageIdx] + 1
    return btn
end

local function addButton(pageIdx, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -6, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(0, 70, 140)
    btn.Text = " ▶ " .. text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.LayoutOrder = ordIdx[pageIdx]
    btn.Parent = pages[pageIdx]
    pcall(function() Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5) end)

    btn.MouseButton1Click:Connect(function() pcall(callback) end)
    ordIdx[pageIdx] = ordIdx[pageIdx] + 1
    return btn
end

