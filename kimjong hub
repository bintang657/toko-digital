-- 11. Fly Hack
local flyEnabled = false
local function fly()
    if Features.FlyHack then
        if not flyEnabled then
            flyEnabled = true
            local char = Utility:GetCharacter()
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and hum then
                local bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.MaxForce = Vector3.new(10000,10000,10000)
                bodyVelocity.Velocity = Vector3.new(0,0,0)
                bodyVelocity.Parent = hrp
                local bodyGyro = Instance.new("BodyGyro")
                bodyGyro.MaxTorque = Vector3.new(10000,10000,10000)
                bodyGyro.CFrame = hrp.CFrame
                bodyGyro.Parent = hrp
                local flyLoop
                flyLoop = game:GetService("RunService").RenderStepped:Connect(function()
                    if not Features.FlyHack then
                        bodyVelocity:Destroy()
                        bodyGyro:Destroy()
                        flyLoop:Disconnect()
                        flyEnabled = false
                        return
                    end
                    local moveDirection = Vector3.new(0,0,0)
                    local userInput = game:GetService("UserInputService")
                    if userInput:IsKeyDown(Enum.KeyCode.W) then
                        moveDirection = moveDirection + hrp.CFrame.LookVector
                    end
                    if userInput:IsKeyDown(Enum.KeyCode.S) then
                        moveDirection = moveDirection - hrp.CFrame.LookVector
                    end
                    if userInput:IsKeyDown(Enum.KeyCode.A) then
                        moveDirection = moveDirection - hrp.CFrame.RightVector
                    end
                    if userInput:IsKeyDown(Enum.KeyCode.D) then
                        moveDirection = moveDirection + hrp.CFrame.RightVector
                    end
                    if userInput:IsKeyDown(Enum.KeyCode.Space) then
                        moveDirection = moveDirection + Vector3.new(0,1,0)
                    end
                    if userInput:IsKeyDown(Enum.KeyCode.LeftControl) then
                        moveDirection = moveDirection - Vector3.new(0,1,0)
                    end
                    bodyVelocity.Velocity = moveDirection * 50
                    bodyGyro.CFrame = hrp.CFrame
                end)
            end
        end
    else
        if flyEnabled then
            flyEnabled = false
        end
    end
end

-- 12. Noclip
local noclipEnabled = false
local function noclip()
    if Features.Noclip then
        if not noclipEnabled then
            noclipEnabled = true
            local char = Utility:GetCharacter()
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            char.ChildAdded:Connect(function(child)
                if child:IsA("BasePart") and Features.Noclip then
                    child.CanCollide = false
                end
            end)
        end
    else
        if noclipEnabled then
            noclipEnabled = false
            local char = Utility:GetCharacter()
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end

