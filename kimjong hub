-- Fungsi untuk membuat string ter-obfuscate
local function obf(str)
    local obfuscated = ""
    for i=1,#str do
        obfuscated = obfuscated .. string.char(string.byte(str,i) + math.random(1,5))
    end
    return obfuscated
