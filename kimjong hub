local function boot()
    print("╔═══════════════════════════════════════════╗")
    print("║     Script KimJong v2.1 - Fish It        ║")
    print("║     Universal Executor Support            ║")
    print("╚═══════════════════════════════════════════╝")

    -- Identify executor
    local executorName = "Unknown"
    pcall(function()
        if identifyexecutor then
            executorName = identifyexecutor()
        elseif getexecutorname then
            executorName = getexecutorname()
        end
    end)
    print("[Boot] Executor: " .. executorName)
    print("[Boot] Capabilities: " .. #_capability .. " functions")

    -- Step 1: Anti-Cheat
    print("[1/4] Anti-cheat initialization...")
    local acResults = AntiCheat.init()
    for k, v in pairs(acResults) do
        print("  " .. k .. ": " .. tostring(v))
    end

    task.wait(0.3)

    -- Step 2: Game Analysis
    print("[2/4] Game analysis...")
    GameData.analyze()

    task.wait(0.3)

    -- Step 3: Anti-AFK
    print("[3/4] Anti-AFK...")
    Features.antiAFK(true)

    -- Step 4: GUI
    print("[4/4] Building GUI...")
    local guiOk = buildGUI()

    if guiOk then
        print("╔═══════════════════════════════════════════╗")
        print("║     ✅ LOADED SUCCESSFULLY!               ║")
        print("║     Toggle UI: RightShift                 ║")
        print("╚═══════════════════════════════════════════╝")

        local rc = 0
        for _, v in pairs(GameData.remotes) do if v then rc = rc + 1 end end

        Util.notify("Script KimJong v2.1",
            "✅ Loaded!\n" ..
            "Executor: " .. executorName .. "\n" ..
            "Mode: " .. (AntiCheat.hooksInstalled and "Full" or "Basic") .. "\n" ..
            "Remotes: " .. rc .. " | Spots: " .. #GameData.locations.fishingSpots ..
            "\nToggle: RightShift", 6)
    end

    -- Handle respawn
    LP.CharacterAdded:Connect(function()
        task.wait(1)
        if States.speedHack then Features.speedHack(true, States.speedValue) end
        if States.noclip then Features.noclip(true) end
        if States.godMode then Features.godMode(true) end
        if States.flyHack then Features.flyHack(true) end
    end)
end

