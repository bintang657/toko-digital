-- SERVER HOP
function F.serverHop()
    Util.notify("Hop", "Finding server...", 3)
    pcall(function()
        local pid = game.PlaceId
        if Exec.request then
            local s2, resp = pcall(function()
                return Exec.request({
                    Url = "https://games.roblox.com/v1/games/"..pid.."/servers/Public?sortOrder=Asc&limit=100",
                    Method = "GET"
                })
            end)
            if s2 and resp and resp.Body then
                local data = HttpService:JSONDecode(resp.Body)
                if data and data.data then
                    local svrs = {}
                    for _, sv in ipairs(data.data) do
                        if sv.playing and sv.maxPlayers and sv.id and
                           sv.playing < sv.maxPlayers and sv.id ~= game.JobId then
                            table.insert(svrs, sv.id)
                        end
                    end
                    if #svrs > 0 then
                        TeleportService:TeleportToPlaceInstance(pid, svrs[math.random(#svrs)], LP)
                        return
                    end
                end
            end
        end
        TeleportService:Teleport(pid, LP)
    end)
end

