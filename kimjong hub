-- Randomized variable names generator
local function _rng_name()
    local _c = {}
    for _i = 1, math.random(8, 16) do
        _c[_i] = string.char(math.random(97, 122))
    end
    return table.concat(_c)
end

-- Random delay untuk anti-pattern detection
local function _rnd_delay(min, max)
    min = min or 0.1
    max = max or 0.5
    local _d = min + math.random() * (max - min)
    task.wait(_d)
    return _d
end

